APP_NAME=Proxima API
ENVIRONMENT=development
DOCS_ENABLED=true

# Local development uses SQLite when this flag is enabled.
USE_SQLITE_FOR_DEVELOPMENT=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/proxima
DATABASE_URL_UNPOOLED=

# Replace both values with different random strings of at least 32 characters.
JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
JWT_REFRESH_SECRET_KEY=replace-with-another-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=proxima-api
JWT_AUDIENCE=proxima-client

# Vercel adds these automatically when the Blob store is connected.
# BLOB_STORE_ID is used with VERCEL_OIDC_TOKEN in deployments; the static
# token is the fallback for local development and external hosts.
BLOB_STORE_ID=
BLOB_READ_WRITE_TOKEN=
